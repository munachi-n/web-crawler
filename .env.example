PORT=3000
NODE_ENV=development
API_KEY=

# Crawler
CRAWLER_MAX_DEPTH=3
CRAWLER_MAX_PAGES=100
CRAWLER_REQUEST_DELAY=1000
CRAWLER_USER_AGENT=WebCrawlerBot/1.0
CRAWLER_RESPECT_ROBOTS=true
CRAWLER_TIMEOUT=10000
CRAWLER_CONCURRENCY=3

# Cache
CACHE_ENABLED=true
CACHE_TTL=300000
CACHE_MAX_SIZE=200

# Rate Limiting
RATE_LIMIT_WINDOW=60000
RATE_LIMIT_MAX=30

# Storage
STORAGE_DIR=./data
