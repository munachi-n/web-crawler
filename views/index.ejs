<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Web Crawler</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <header>
    <h1>Web Crawler</h1>
    <p>An open source web crawler built with Node.js and Cheerio</p>
  </header>

  <main>
    <section id="crawler-form">
      <h2>Start a Crawl</h2>
      <form id="crawlForm">
        <div class="form-group">
          <label for="url">URL to crawl:</label>
          <input type="url" id="url" name="url" placeholder="https://example.com" required>
        </div>
        <div class="form-group">
          <label for="maxDepth">Max Depth:</label>
          <input type="number" id="maxDepth" name="maxDepth" min="0" max="10" value="2">
        </div>
        <div class="form-group">
          <label for="maxPages">Max Pages:</label>
          <input type="number" id="maxPages" name="maxPages" min="1" max="500" value="50">
        </div>
        <button type="submit">Start Crawl</button>
      </form>
    </section>

    <section id="results">
      <h2>Results</h2>
      <div id="stats"></div>
      <div id="results-list"></div>
    </section>
  </main>

  <footer>
    <p>Web Crawler &copy; 2023</p>
  </footer>

  <script src="/js/app.js"></script>
</body>
</html>
